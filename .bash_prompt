source "${HOME}/.prompt_common"

# Box drawing character style prompt for Bash
PS1='\n'
PS1+='\[${gray}\]в”Њв”Ђ'
PS1+='$(prompt_time)'
PS1+='\[${gray}\]в”Ђ[\[${reset}\]'
PS1+='\u'  # username
PS1+='\[${gray}\]]в”Ђ[\[${reset}\]'
PS1+='\W'  # working directory
PS1+='\[${gray}\]]'
PS1+='$(prompt_git_box)'
PS1+='$(prompt_exit_status)'
PS1+='$(prompt_jobs_box)'
PS1+='\n'
PS1+='\[${gray}\]в””в”Ђ>\[${reset}\] '
export PS1

PS2='\[${gray}\]в”Ђв”Ђв”Ђ>\[${reset}\] '
export PS2
