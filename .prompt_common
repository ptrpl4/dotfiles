# Terminal formatting and colors
gray=$(tput setaf 8)
reset=$(tput sgr0)

# Current time display
prompt_time() {
    local raw=$(date +"%H:%M")
    local h="${raw%%:*}"
    local m="${raw##*:}"
    printf "%b‚îÄ[%b%s%b:%b%s%b]" "${gray}" "${reset}" "$h" "${gray}" "${reset}" "$m" "${gray}"
}

# Box drawing style git prompt with colors (optimized)
prompt_git_box() {
    git rev-parse --is-inside-work-tree &>/dev/null || return

    local git_status=''
    local branchName=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null || echo '(unknown)')

    if [[ -n "$ZSH_VERSION" ]]; then
        branchName=${branchName:l}
    else
        branchName=$(echo "$branchName" | tr '[:upper:]' '[:lower:]')
    fi

    local upstream=$(git rev-parse --abbrev-ref @{upstream} 2>/dev/null)
    if [[ -n "$upstream" ]]; then
        local ahead_behind=$(git rev-list --left-right --count HEAD...@{upstream} 2>/dev/null)
        local ahead=${ahead_behind%%[[:space:]]*}
        local behind=${ahead_behind##*[[:space:]]}
        ahead=${ahead:-0}
        behind=${behind:-0}

        [[ "$behind" -gt 0 ]] && git_status+="‚Üì${behind}"
        [[ "$ahead" -gt 0 ]] && git_status+="‚Üë${ahead}"

        if [[ "$ahead" -eq 0 ]] && [[ "$behind" -eq 0 ]]; then
            git_status+="‚úì"
        fi
    fi

    [[ -n "${git_status}" ]] && git_status="${gray}:${reset}${git_status}"

    printf "%b‚îÄ[%bgit%b:%b%s%s%b]" "${gray}" "${reset}" "${gray}" "${reset}" "${branchName}" "${git_status}" "${gray}"
}

# Zsh preexec hook ‚Äî record time before each command
preexec() {
    timer=$SECONDS
}

# Bash preexec support via DEBUG trap
if [[ -n "$BASH_VERSION" ]]; then
    __prompt_command() {
        local exit_code=$?
        LAST_EXIT_CODE=$exit_code
        __preexec_invoked=
        return $exit_code
    }

    __debug_trap() {
        [[ -n "$__preexec_invoked" ]] && return
        [[ -z "${BASH_COMMAND// }" ]] && return
        case "$BASH_COMMAND" in
            __prompt_command*|__debug_trap*|'return '*) return ;;
            *'PROMPT_COMMAND'*) return ;;
        esac
        timer=$SECONDS
        __preexec_invoked=1
    }

    trap '__debug_trap' DEBUG
    PROMPT_COMMAND='__prompt_command'
fi

# Zsh precmd hook ‚Äî capture exit code after each command
if [[ -n "$ZSH_VERSION" ]]; then
    precmd() {
        local exit_code=$?
        LAST_EXIT_CODE=$exit_code
        return $exit_code
    }
fi

# Show elapsed seconds if command took >= 1s
prompt_exec_time_box() {
    if [[ -n "$timer" ]]; then
        local elapsed=$(( SECONDS - timer ))
        if [[ $elapsed -gt 0 ]]; then
            printf "%b‚îÄ[%b%ds%b]" "${gray}" "${reset}" "${elapsed}" "${gray}"
        fi
        unset timer
    fi
}

# Exit status indicator
prompt_exit_status() {
    if [[ -n "$LAST_EXIT_CODE" ]] && [[ "$LAST_EXIT_CODE" -ne 0 ]]; then
        printf "%b‚îÄ[%berr %d%b]" "${gray}" "${reset}" "$LAST_EXIT_CODE" "${gray}"
    fi
}

# Background jobs indicator
prompt_jobs_box() {
    local job_count=$(jobs -p 2>/dev/null | wc -l)
    job_count=${job_count// /}
    if [[ $job_count -gt 0 ]]; then
        printf "%b‚îÄ[%bjobs %d%b]" "${gray}" "${reset}" "${job_count}" "${gray}"
    fi
}
