# andorid emul
alias android-1="emulator @Pixel_3a_API_34_extension_level_7_arm64-v8a -memory 1024 -partition-size 512 -no-boot-anim"
alias android-2="emulator -avd Pixel_3_API_30 -memory 1024 -partition-size 512 -no-boot-anim"

# python
alias python=python3
alias pip=pip3

# shell
alias reload='exec $SHELL -l'
alias cs='claude-sessions'

## multiuser 'support'
brew-fix() { sudo chown -R "$(whoami)" /opt/homebrew; }
